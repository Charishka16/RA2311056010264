generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  passwordHash String
  name         String
  role         String      @default("USER")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?
  orgMembers   OrgMember[]
  createdOrgs  Organization[] @relation("OrgCreator")
  createdProjs Project[]   @relation("ProjectCreator")
}

model Organization {
  id        String      @id @default(uuid())
  name      String
  slug      String      @unique
  createdBy String
  creator   User        @relation("OrgCreator", fields: [createdBy], references: [id])
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  members   OrgMember[]
  projects  Project[]
}

model OrgMember {
  id       String       @id @default(uuid())
  orgId    String
  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId   String
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     String       @default("MEMBER")
  createdAt DateTime    @default(now())

  @@unique([orgId, userId])
}

model Project {
  id        String       @id @default(uuid())
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name      String
  slug      String
  createdBy String
  creator   User         @relation("ProjectCreator", fields: [createdBy], references: [id])
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  queues    Queue[]

  @@unique([orgId, slug])
}

model RetryPolicy {
  id            String   @id @default(uuid())
  name          String
  type          String   @default("FIXED")
  baseDelayMs   Int      @default(1000)
  maxDelayMs    Int?
  backoffFactor Float?
  maxRetries    Int      @default(3)
  createdAt     DateTime @default(now())
  queues        Queue[]
}

model Queue {
  id               String       @id @default(uuid())
  projectId        String
  project          Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name             String
  description      String?
  priority         Int          @default(0)
  concurrencyLimit Int          @default(10)
  retryPolicyId    String?
  retryPolicy      RetryPolicy? @relation(fields: [retryPolicyId], references: [id])
  isPaused         Boolean      @default(false)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  jobs             Job[]
  scheduledJobs    ScheduledJob[]
  dlqEntries       DeadLetterQueue[]

  @@unique([projectId, name])
}

model Job {
  id             String    @id @default(uuid())
  queueId        String
  queue          Queue     @relation(fields: [queueId], references: [id], onDelete: Cascade)
  name           String
  type           String    @default("IMMEDIATE")
  status         String    @default("QUEUED")
  payload        String    @default("{}")
  priority       Int       @default(0)
  scheduledAt    DateTime  @default(now())
  startedAt      DateTime?
  completedAt    DateTime?
  failedAt       DateTime?
  claimedAt      DateTime?
  attempt        Int       @default(0)
  maxRetries     Int       @default(3)
  timeoutMs      Int       @default(300000)
  idempotencyKey String?   @unique
  version        Int       @default(1)
  workerId       String?
  worker         Worker?   @relation(fields: [workerId], references: [id], onDelete: SetNull)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  executions     JobExecution[]
  logs           JobLog[]
  dlqEntry       DeadLetterQueue?

  @@index([status, scheduledAt, priority])
}

model JobExecution {
  id           String    @id @default(uuid())
  jobId        String
  job          Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  attempt      Int
  workerId     String
  worker       Worker    @relation(fields: [workerId], references: [id], onDelete: Cascade)
  status       String
  startedAt    DateTime  @default(now())
  completedAt  DateTime?
  durationMs   Int?
  errorMessage String?
  result       String?
}

model JobLog {
  id        String   @id @default(uuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  level     String
  message   String
  metadata  String?
  createdAt DateTime @default(now())
}

model ScheduledJob {
  id             String    @id @default(uuid())
  queueId        String
  queue          Queue     @relation(fields: [queueId], references: [id], onDelete: Cascade)
  name           String
  cronExpression String
  timezone       String    @default("UTC")
  payload        String    @default("{}")
  priority       Int       @default(0)
  maxRetries     Int       @default(3)
  isActive       Boolean   @default(true)
  lastRunAt      DateTime?
  nextRunAt      DateTime?
  totalRuns      Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model DeadLetterQueue {
  id            String    @id @default(uuid())
  jobId         String    @unique
  job           Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  queueId       String
  queue         Queue     @relation(fields: [queueId], references: [id], onDelete: Cascade)
  failureReason String
  failureCount  Int
  lastError     String?
  createdAt     DateTime  @default(now())
  purgedAt      DateTime?
  retriedAt     DateTime?
}

model Worker {
  id            String            @id @default(uuid())
  name          String
  hostname      String
  pid           Int
  status        String            @default("ACTIVE")
  startedAt     DateTime          @default(now())
  stoppedAt     DateTime?
  lastHeartbeat DateTime          @default(now())
  jobsProcessed Int               @default(0)
  jobsFailed    Int               @default(0)
  heartbeats    WorkerHeartbeat[]
  jobs          Job[]
  executions    JobExecution[]
}

model WorkerHeartbeat {
  id        String   @id @default(uuid())
  workerId  String
  worker    Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  status    String   @default("healthy")
  createdAt DateTime @default(now())
}
